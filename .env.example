# Ringba API – shared by Accounting and State Performance
# Get your apiToken from Ringba (company settings / API). Base URL optional; default is https://api.ringba.com
# RINGBA_API_BASE_URL=https://api.ringba.com
# RINGBA_API_KEY=your_ringba_api_token_here
# RINGBA_ACCOUNT_ID=RA417e311c6e8b47538624556e6e84298a

# Roku Ads API (beta) — ad accounts + spend reports (NOT Conversions/CAPI)
# Register app in Roku Ads Manager → Settings. OAuth once, then store refresh token.
# ROKU_ADS_API_BASE_URL=https://api.ads.roku.com/v1
# ROKU_ADS_CLIENT_ID=
# ROKU_ADS_CLIENT_SECRET=
# ROKU_ADS_REFRESH_TOKEN=
# ROKU_ADS_ACCESS_TOKEN=   # optional short-lived bypass instead of refresh flow
# ROKU_ADS_REQUEST_TIMEOUT_MS=120000
# ROKU_ADS_CACHE_CHUNK_DAYS=7
# ROKU_ADS_CACHE_CHUNK_POLL_MAX=200

# CallGrid — credentials stored per company in MongoDB (platform=callgrid), not in env.
# Optional defaults for test-data date range / API host:
# CALLGRID_API_BASE_URL=https://api.callgrid.com
# CALLGRID_REPORT_TIME_ZONE=US/Eastern
# CALLGRID_REPORT_RANGE_START=2026-05-04
# CALLGRID_REPORT_RANGE_END=2026-05-08

# Retreaver API - for accounting platform=retriever companies
# RETREAVER_API_BASE_URL=https://api.retreaver.com
# RETREAVER_API_KEY=your_retreaver_api_key_here
# RETREAVER_COMPANY_ID=your_default_company_id_for_test_endpoint

# Google Ads Offline Conversion API
# GOOGLE_ADS_CLIENT_ID=your_google_ads_oauth_client_id
# GOOGLE_ADS_CLIENT_SECRET=your_google_ads_oauth_client_secret
# GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
# GOOGLE_ADS_REFRESH_TOKEN=your_google_ads_refresh_token
# GOOGLE_ADS_API_VERSION=v22
# GOOGLE_ADS_VALIDATE_ONLY=0
# GOOGLE_ADS_DRY_RUN=0

# Dynamic Ring Tree Target (FE tier RPC → auto tier moves)
# DYNAMIC_RING_TREE_DRY_RUN=true
# DYNAMIC_RING_TREE_MOVE_COOLDOWN_MS=1800000
# DYNAMIC_RING_TREE_REVENUE_BACKFILL=true
# DYNAMIC_RING_TREE_REVENUE_BACKFILL_DELAY_MS=0
# DYNAMIC_RING_TREE_SKIP_DEMOTION_ON_ZERO_RPC=true
# DYNAMIC_RING_TREE_REVENUE_BACKFILL_ONLY_ZERO_PIXEL=false
# DYNAMIC_RING_TREE_DAILY_BATCH_RESET=true
# DYNAMIC_RING_TREE_DAILY_BATCH_RESET_TIMEZONE=America/New_York
# DYNAMIC_RING_TREE_DAILY_BATCH_RESET_HOUR=1
# DYNAMIC_RING_TREE_FE_TIER1_ID=PI943e1abfb7c84cbdbdf12b5fed5db525
# DYNAMIC_RING_TREE_FE_TIER2_ID=PIfd7e2f930c1943dda25f3cfc290c1d9c
# DYNAMIC_RING_TREE_FE_TIER3_ID=PId770038dc60d4aef9d2a735a629b1fca
# Future verticals (set enabled + tier IDs when ready):
# DYNAMIC_RING_TREE_MEDICARE_ENABLED=false
# DYNAMIC_RING_TREE_DEBT_ENABLED=false
# DYNAMIC_RING_TREE_ACA_ENABLED=false
